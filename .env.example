PORT=3000
NODE_ENV=development

# Comma-separated, no spaces. Production + all Vercel previews:
#   https://your-app.vercel.app,*.vercel.app
# Local:
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Allow any origin (dev only). Set CORS_DEV_BYPASS=true for local convenience. Never set in production.
# CORS_DEV_BYPASS=false

# Supabase (free tier): Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# JWT for /api/auth and /api/leaderboard/add-points (set a long random secret in production)
JWT_SECRET=change-me-in-production

# Optional tuning
GAME_MIN_PLAYERS=2
GAME_MAX_PLAYERS_PER_ROOM=8
ROUNDS_PER_MATCH=3
ROUND_DURATION_MS=60000
LOBBY_COUNTDOWN_MS=3000
POSITION_UPDATE_MAX_PER_SEC=20
ACTION_UPDATE_MAX_PER_SEC=10
BASE_ROUND_SURVIVAL_POINTS=10

# Set to true to serve index.html from this repo (local convenience). Frontend on Vercel should not need this.
SERVE_STATIC=false
