PORT=3000
NODE_ENV=development

# Comma-separated list. Add your Vercel production URL, e.g. https://your-app.vercel.app
# Use * only for local experiments (avoid in production with credentials).
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Supabase (free tier): Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional tuning
GAME_MIN_PLAYERS=2
GAME_MAX_PLAYERS_PER_ROOM=8
ROUNDS_PER_MATCH=3
ROUND_DURATION_MS=60000
LOBBY_COUNTDOWN_MS=3000
POSITION_UPDATE_MAX_PER_SEC=20
ACTION_UPDATE_MAX_PER_SEC=10
BASE_ROUND_SURVIVAL_POINTS=10

# Set to true to serve index.html from this repo (local convenience). Frontend on Vercel should not need this.
SERVE_STATIC=false
